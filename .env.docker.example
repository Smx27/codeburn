# AiInsight Cloud - Docker Environment
# Copy this to .env and fill in the values
#
# For Coolify: set NEXT_PUBLIC_API_URL and NEXT_PUBLIC_APP_URL to your
# external service URLs (e.g. https://api.yourdomain.com and https://app.yourdomain.com)

# PostgreSQL (port exposed on host — internal stays 5432)
POSTGRES_DB=aiinsight
POSTGRES_USER=aiinsight
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_PORT=5433

# JWT (required — shared between ingestion-api and dashboard-api)
JWT_SECRET=change-me-in-production

# Ingestion API
INGESTION_API_PORT=3001
INGESTION_BASE_URL=http://localhost:3001
REQUIRE_INGEST_AUTH=true

# Dashboard API
DASHBOARD_API_PORT=3002
CORS_ORIGIN=http://localhost:3000
APP_URL=http://localhost:3000
MAIL_PROVIDER=resend
RESEND_API_KEY=
MAIL_FROM=AIInsight <noreply@aiinsight.dev>

# SMTP (if using smtp mail provider instead of resend)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Dashboard Web
# IMPORTANT: In Coolify, set these to the EXTERNAL URLs of each service
# e.g. NEXT_PUBLIC_API_URL=https://api.yourdomain.com
#      NEXT_PUBLIC_APP_URL=https://app.yourdomain.com
DASHBOARD_WEB_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:3002
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Logging
LOG_LEVEL=info
