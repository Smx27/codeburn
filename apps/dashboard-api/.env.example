# Database
DATABASE_URL=postgresql://user:password@localhost:5432/aiinsight

# Server
PORT=3002
NODE_ENV=development

# Logging
LOG_LEVEL=info

# JWT
JWT_SECRET=your-secret-key-change-in-production

# CORS
CORS_ORIGIN=http://localhost:3000

# Frontend URL (for email links)
APP_URL=http://localhost:3000

# Ingestion API URL (for agent sync — Docker-internal)
INGESTION_API_URL=http://ingestion-api:3001

# External ingestion API URL (for CLI clients outside Docker)
INGESTION_API_EXTERNAL_URL=https://ingestion.titanbyte.in

# Mail Provider (resend or smtp)
MAIL_PROVIDER=resend

# Resend (if using resend)
RESEND_API_KEY=your-resend-api-key

# SMTP (if using smtp)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your-smtp-user
# SMTP_PASS=your-smtp-password
# SMTP_FROM=noreply@example.com