    {
      "_type": "request",
      "_id": "req_01_register",
      "parentId": "fldr_setup",
      "name": "1.1 Register User + Org",
      "method": "POST",
      "url": "{{ _.dashboard_api }}/api/v1/auth/register",
      "headers": [
        { "name": "Content-Type", "value": "application/json" }
      ],
      "body": {
        "mimeType": "application/json",
        "text": "{\n  \"email\": \"test@example.com\",\n  \"password\": \"testpassword123\",\n  \"name\": \"Test User\",\n  \"organizationName\": \"Test Org\"\n}"
      },
      "scripts": {
        "afterResponse": [
          "const body = JSON.parse(res.getBody());",
          "if (body.token) {",
          "  insomnia.environment.set('jwt_token', body.token);",
          "  if (body.organization) insomnia.environment.set('organization_id', body.organization.id);",
          "  if (body.user && body.user.organizationId) insomnia.environment.set('organization_id', body.user.organizationId);",
          "}",
          "console.log('Register:', JSON.stringify(body, null, 2));"
        ]
      }
    },
    {
      "_type": "request",
      "_id": "req_02_login",
      "parentId": "fldr_setup",
      "name": "1.2 Login (get JWT)",
      "method": "POST",
      "url": "{{ _.dashboard_api }}/api/v1/auth/login",
      "headers": [
        { "name": "Content-Type", "value": "application/json" }
      ],
      "body": {
        "mimeType": "application/json",
        "text": "{\n  \"email\": \"test@example.com\",\n  \"password\": \"testpassword123\"\n}"
      },
      "scripts": {
        "afterResponse": [
          "const body = JSON.parse(res.getBody());",
          "if (body.token) {",
          "  insomnia.environment.set('jwt_token', body.token);",
          "  if (body.user && body.user.organizationId) insomnia.environment.set('organization_id', body.user.organizationId);",
          "}",
          "console.log('Login:', JSON.stringify(body, null, 2));"
        ]
      }
    },
    {
      "_type": "request",
